---
interface Props {
  lang?: 'es' | 'en';
}

const { lang = 'es' } = Astro.props;

const navItems = lang === 'es' 
  ? [
      { href: '/es/', label: 'Inicio' },
      { href: '/es/capitulos/', label: 'Capítulos' },
      { href: '/es/sobre-kaira/', label: 'Sobre Kaira' }
    ]
  : [
      { href: '/en/', label: 'Home' },
      { href: '/en/chapters/', label: 'Chapters' },
      { href: '/en/about-kaira/', label: 'About Kaira' }
    ];

const otherLang = lang === 'es' ? 'en' : 'es';
const otherLangLabel = lang === 'es' ? 'EN' : 'ES';
const otherLangHref = lang === 'es' ? '/en/' : '/es/';
---

<header class="sticky top-0 z-50 bg-bg-primary/95 backdrop-blur-sm border-b border-accent/10">
  <nav class="container-wide flex items-center justify-between h-16 md:h-20">
    <a href={lang === 'es' ? '/es/' : '/en/'} class="flex items-center gap-2 hover:no-underline">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 40 40" width="32" height="32" class="md:w-10 md:h-10">
        <circle cx="20" cy="20" r="18" fill="none" stroke="currentColor" stroke-width="2" class="text-accent"/>
        <path d="M20 8 L20 20 L28 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="text-accent"/>
        <circle cx="20" cy="20" r="2" fill="currentColor" class="text-accent"/>
      </svg>
      <span class="font-serif text-xl md:text-2xl font-bold text-text-primary">TimeCrawler</span>
    </a>

    <div class="flex items-center gap-4 md:gap-6">
      <ul class="hidden md:flex items-center gap-6">
        {navItems.map((item) => (
          <li>
            <a 
              href={item.href} 
              class="text-text-secondary hover:text-accent transition-colors duration-200 font-medium"
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>

      <a 
        href={otherLangHref}
        class="px-3 py-1 text-sm font-medium border border-accent/30 rounded hover:bg-accent/10 transition-colors duration-200"
        id="lang-switcher"
        data-target-lang={otherLang}
      >
        {otherLangLabel}
      </a>

      <button 
        id="menu-toggle"
        class="md:hidden p-2 text-text-primary hover:text-accent transition-colors"
        aria-label="Toggle menu"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="12" x2="21" y2="12" class="menu-icon-line"></line>
          <line x1="3" y1="6" x2="21" y2="6" class="menu-icon-line"></line>
          <line x1="3" y1="18" x2="21" y2="18" class="menu-icon-line"></line>
        </svg>
      </button>
    </div>
  </nav>

  <div id="mobile-menu" class="md:hidden hidden border-t border-accent/10">
    <ul class="container-wide py-4 space-y-3">
      {navItems.map((item) => (
        <li>
          <a 
            href={item.href} 
            class="block py-2 text-text-secondary hover:text-accent transition-colors duration-200 font-medium"
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  // Auto-detect language on first visit
  const savedLang = localStorage.getItem('preferred-lang');
  const currentPath = window.location.pathname;
  
  if (!savedLang) {
    const browserLang = navigator.language.toLowerCase().split('-')[0];
    const targetLang = browserLang === 'es' ? 'es' : 'en';
    const currentLang = currentPath.includes('/es/') ? 'es' : 'en';
    
    if (targetLang !== currentLang) {
      localStorage.setItem('preferred-lang', targetLang);
      const newPath = targetLang === 'es' ? '/es/' : '/en/';
      if (currentPath !== newPath && (currentPath.endsWith('/timecrawler-web-dev/') || currentPath.endsWith('/timecrawler-web-dev'))) {
        window.location.href = newPath;
      }
    }
  }
  
  // Save language preference when switching
  const langSwitcher = document.getElementById('lang-switcher');
  if (langSwitcher) {
    const targetLang = langSwitcher.getAttribute('data-target-lang');
    langSwitcher.addEventListener('click', () => {
      if (targetLang) {
        localStorage.setItem('preferred-lang', targetLang);
      }
    });
  }
  
  // Mobile menu toggle
  const menuToggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  
  if (menuToggle && mobileMenu) {
    menuToggle.addEventListener('click', () => {
      mobileMenu.classList.toggle('hidden');
    });
  }
</script>
